# ── Personal data — NEVER commit these ──────────────────────────
profile.yml          # contains real name, email, phone, salary targets
jobs.db              # your actual job application database
digests/             # LLM-scored job digest files
clients/             # per-client profile directories

# ── Runtime / cache ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Dev artifacts ────────────────────────────────────────────────
archive/
.last_discovery
*.log
*.tmp
.env
.env.*

# ── Scraped HTML snapshots (may contain session data) ────────────
*_rendered.html
linkedin_rendered.html

# ── OS / editor ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
